---
interface Props {
  value: string;
  label: string;
  detail: string;
}

const { value, label, detail } = Astro.props;
---

<article class="stat-card h-full rounded-[30px] p-6 sm:p-7">
  <p class="value-display mb-5 gradient-text">{value}</p>
  <h3 class="feature-title mb-3 text-2xl tracking-[-0.05em] text-[var(--text)]">{label}</h3>
  <p class="body-copy text-sm">{detail}</p>
</article>
