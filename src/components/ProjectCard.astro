---
interface Props {
  name: string;
  role: string;
  period: string;
  context: string;
  actions: string[];
  outcome: string;
  tags: string[];
}

const { name, role, period, context, actions, outcome, tags } = Astro.props;
---

<article class="project-card flex h-full flex-col rounded-[32px] p-6 sm:p-7">
  <div class="mb-5 flex items-start justify-between gap-4">
    <div>
      <p class="mini-label mb-3">{period}</p>
      <h3 class="feature-title text-3xl tracking-[-0.06em] text-[var(--text)]">{name}</h3>
      <p class="mt-2 text-sm text-[var(--text-secondary)]">{role}</p>
    </div>
  </div>

  <p class="body-copy mb-5 text-sm">{context}</p>

  <ul class="mb-6 space-y-3 pl-5 text-sm leading-7 text-[var(--text)] marker:text-[var(--accent)]">
    {actions.map((action) => <li>{action}</li>)}
  </ul>

  <div class="case-outcome mb-6 rounded-[24px] p-5 text-sm leading-7 text-[var(--text)]">
    {outcome}
  </div>

  <div class="mt-auto flex flex-wrap gap-2">
    {tags.map((tag) => <span class="tag rounded-full px-3 py-1.5 text-xs uppercase tracking-[0.12em] text-[var(--text-secondary)]">{tag}</span>)}
  </div>
</article>
