---
import '../styles/global.css';
import { defaultLocale, labels, resumeData, type Locale } from '../data/resume';

interface Props {
  locale?: Locale;
  title?: string;
  description?: string;
  pdfMode?: boolean;
  switchHref?: string;
  alternateLocale?: Locale;
}

const {
  locale = defaultLocale,
  title,
  description,
  pdfMode = false,
  switchHref,
  alternateLocale
} = Astro.props;
const seoTitle = title ?? resumeData.seo.title[locale];
const seoDescription = description ?? resumeData.seo.description[locale];
const navLabels = labels[locale];
---

<!doctype html>
<html lang={locale} class:list={{ 'pdf-mode': pdfMode }}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoTitle}</title>
    <meta name="description" content={seoDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  </head>
  <body class:list={{ 'pdf-mode': pdfMode }}>
    <div class="site-background"></div>
    <div class="mx-auto min-h-screen max-w-[1280px] px-4 py-5 sm:px-6 lg:px-10 lg:py-8">
      <header class:list={{ topbar: true, 'section-shell': true, 'sticky top-4 z-20 mb-8 rounded-full px-4 py-3 sm:px-6': !pdfMode, 'mb-6 rounded-[28px] px-5 py-3 sm:px-6': pdfMode }}>
        <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
          <a href="#top" class="text-sm font-semibold tracking-[0.18em] text-[var(--text)] no-underline uppercase">{resumeData.profile.name}</a>
          <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:gap-4">
            <nav class:list={{ 'flex flex-wrap items-center gap-2 text-sm text-[var(--text-secondary)]': true, hidden: pdfMode }}>
              <a href="#about" class="nav-pill">{navLabels.about}</a>
              <a href="#experience" class="nav-pill">{navLabels.experience}</a>
              <a href="#projects" class="nav-pill">{navLabels.projects}</a>
              <a href="#skills" class="nav-pill">{navLabels.skills}</a>
              <a href="#contact" class="nav-pill">{navLabels.contact}</a>
            </nav>
            <div class="flex items-center gap-2">
              {switchHref && alternateLocale && (
                <a href={switchHref} class="lang-switch rounded-full border border-[var(--line-strong)] px-3 py-2 text-xs font-semibold uppercase tracking-[0.16em] text-[var(--text)]">
                  {alternateLocale.toUpperCase()}
                </a>
              )}
              <div class:list={{ 'mini-label': true, hidden: !pdfMode }}>
                PDF / Print Mode
              </div>
            </div>
          </div>
        </div>
      </header>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>
